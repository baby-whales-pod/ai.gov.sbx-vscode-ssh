# Runtime / SSH configuration (image identity lives in config.env).
# Override any of these inline, e.g. SSH_PORT=2255 ./start.sh

SANDBOX_NAME=better-ssh
SSH_HOST_ALIAS=sbx-better-ssh
SSH_USER=agent
SSH_PORT=2244

# Public key injected into the sandbox (must match a key your SSH agent holds).
SSH_PUBKEY=~/.ssh/id_ed25519.pub

# The template image comes from config.env ($DOCKER_HANDLE/$NAME:$TAG) and is
# passed to `sbx run claude -t …`. Uncomment to override the tag for a run:
# TEMPLATE_TAG=philippecharriere494/sbx-remote-ssh:0.0.0
